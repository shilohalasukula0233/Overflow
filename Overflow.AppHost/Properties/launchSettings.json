{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true, //是否在调试时自动打开浏览器
      "applicationUrl": "https://localhost:5002;http://localhost:5001", //https和http环境下的端口设置
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "https://localhost:21143",
        "ASPIRE_DASHBOARD_MCP_ENDPOINT_URL": "https://localhost:23013",
        "ASPIRE_RESOURCE_SERVICE_ENDPOINT_URL": "https://localhost:22210"
      }
    },
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:5001",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:19091",
        "ASPIRE_DASHBOARD_MCP_ENDPOINT_URL": "http://localhost:18057",
        "ASPIRE_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:20230"
      }
    }
  }
}
